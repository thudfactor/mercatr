LASTFM_API_KEY=your_lastfm_api_key_here

# LLM backend switch: claude | openai-compat
LLM_PROVIDER=claude

# Claude config (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TRACK_EXTRACT_MODEL=claude-haiku-4-5-20251001

# OpenAI-compatible config example (used when LLM_PROVIDER=openai-compat)
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=your_openai_or_compatible_api_key_here
# OPENAI_COMPAT_MODEL=gpt-4o-mini
# OPENAI_COMPAT_TRACK_EXTRACT_MODEL=gpt-4o-mini

# Web server (required when running `npm run serve`)
BASIC_AUTH_USER=your_username_here
BASIC_AUTH_PASSWORD=your_password_here

# Optional
LASTFM_CACHE_TTL_HOURS=24
